# =============================================
# CONFIGURACIÓN DE ENTORNO - EJEMPLO
# =============================================
# Copia este archivo como .env y configura tus valores reales

# =============================================
# SERVIDOR
# =============================================
PORT=5000
NODE_ENV=development

# =============================================
# BASE DE DATOS
# =============================================
# ⚠️  IMPORTANTE: Cambia estas credenciales en producción
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=tiendacel
DB_USER=root
DB_PASSWORD=tu_contraseña_segura_aqui

# =============================================
# SEGURIDAD - JWT
# =============================================
# ⚠️  CRÍTICO: Genera una clave segura aleatoria
# Usa: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=tu_jwt_secret_muy_seguro_minimo_64_caracteres_aleatorios_aqui

# Tiempo de expiración del token (ejemplo: 24h, 7d, 30d)
JWT_EXPIRES_IN=24h

# =============================================
# CLOUDINARY (Subida de imágenes)
# =============================================
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# =============================================
# EMAIL (Nodemailer)
# =============================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu_email@gmail.com
EMAIL_PASSWORD=tu_contraseña_de_aplicacion

# Remitente que aparecerá en los emails
EMAIL_FROM=DR CELL 2.0 <noreply@drcell.com>

# =============================================
# CORS - Dominios permitidos
# =============================================
# En desarrollo: http://localhost:5173
# En producción: https://tudominio.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# =============================================
# RATE LIMITING
# =============================================
# Máximo de peticiones por ventana de tiempo
RATE_LIMIT_MAX=100
# Ventana de tiempo en minutos
RATE_LIMIT_WINDOW=15

# =============================================
# NOTAS IMPORTANTES PARA PRODUCCIÓN
# =============================================
# 1. NUNCA subas el archivo .env al repositorio
# 2. Usa contraseñas FUERTES y únicas para cada servicio
# 3. Genera JWT_SECRET aleatorio con el comando proporcionado arriba
# 4. Configura SSL/HTTPS en producción
# 5. Cambia NODE_ENV=production en producción
# 6. Actualiza ALLOWED_ORIGINS con tu dominio real
# 7. Considera usar un servicio de gestión de secretos (AWS Secrets Manager, etc.)
